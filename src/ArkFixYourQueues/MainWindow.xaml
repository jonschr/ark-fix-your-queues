<Window x:Class="ArkFixYourQueues.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ArkFixYourQueues"
        Title="ARK Join Assist v0.18.0" Width="1050" Height="800" MinWidth="820" MinHeight="620"
        Background="{StaticResource PageBrush}" WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource PageBrush}">
        <Grid Margin="20" Background="{StaticResource PageBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ARK Join Assist" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="#E4E4E7" CornerRadius="4" Padding="9,4" Margin="12,1,0,0" VerticalAlignment="Center">
                        <TextBlock Text="VERSION 0.18.0" FontSize="11" FontWeight="Bold" Foreground="#52525B" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ATTEMPT SPACING" Style="{StaticResource MetricLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="DelaySecondsBox" Text="5" Width="54" Height="34" Padding="8,5" FontSize="13" TextAlignment="Center" VerticalContentAlignment="Center" />
                    <TextBlock Text="SEC" Style="{StaticResource MetricLabel}" VerticalAlignment="Center" Margin="7,0,0,0" />
                    <TextBlock Text="PER CLICK" Style="{StaticResource MetricLabel}" VerticalAlignment="Center" Margin="16,0,8,0" />
                    <TextBox x:Name="PerClickDelayBox" Text="0.5" Width="48" Height="34" Padding="7,5" FontSize="13" TextAlignment="Center" VerticalContentAlignment="Center" ToolTip="Wait this long before every automated click." />
                    <TextBlock Text="SEC" Style="{StaticResource MetricLabel}" VerticalAlignment="Center" Margin="7,0,0,0" />
                    <CheckBox x:Name="PreAlertRecoveryBox" Content="Pre-alert recovery" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button x:Name="StartButton" Content="GO" ToolTip="Global shortcut: Ctrl+G" Height="58" Background="#15803D" Foreground="White" BorderThickness="0" FontSize="16" Click="Start_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="GoBackground" Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="GoBackground" Property="Background" Value="#166534" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="GoBackground" Property="Background" Value="#71717A" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="1" x:Name="StopButton" Content="STOP" ToolTip="Global shortcut: Ctrl+G" Height="58" Margin="12,0,0,0" Background="#BE123C" BorderThickness="0" FontSize="16" IsEnabled="False" Click="Stop_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="StopBackground" Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock x:Name="StopLabel" Text="{TemplateBinding Content}" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="StopBackground" Property="Background" Value="#9F1239" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="StopBackground" Property="Background" Value="#A1A1AA" />
                                    <Setter TargetName="StopLabel" Property="Foreground" Value="#3F3F46" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="18">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Border Background="#F4F4F5" CornerRadius="6" Padding="12,8" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Grid.Column="1" Text="This Go" Style="{StaticResource MetricLabel}" TextAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="This app" Style="{StaticResource MetricLabel}" TextAlignment="Center" />
                                <TextBlock Grid.Row="1" Text="Attempts" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,7,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CurrentGoAttemptsText" Text="0" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,4,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LaunchAttemptsText" Text="0" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,4,0,0" />
                                <TextBlock Grid.Row="2" Text="Avg. sec / attempt" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,5,0,0" ToolTip="Stopped time is excluded." />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CurrentGoAverageText" Text="—" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0" />
                                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="LaunchAverageText" Text="—" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0" />
                                <TextBlock Grid.Row="3" Text="Loading globes" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,5,0,0" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CurrentGoGlobesText" Text="0" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0" />
                                <TextBlock Grid.Row="3" Grid.Column="2" x:Name="LaunchGlobesText" Text="0" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0" />
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" x:Name="CopyLogsButton" Content="COPY LOGS" MinHeight="36" Padding="14,6" FontSize="11" VerticalAlignment="Center" Click="CopyLogs_OnClick" />
                    </Grid>
                    <StackPanel>
                        <Border Background="#FAFAFA" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Delay performance" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="All-time loading-globe yield" Style="{StaticResource MetricLabel}" Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" x:Name="DelayPerformancePanel" Orientation="Horizontal" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock Text="Latest ASA screen" Style="{StaticResource MetricLabel}" Margin="0,0,0,7" />
                        <local:AspectRatioBorder x:Name="ScreenPreviewBorder" AspectRatio="1.7777778" Background="#18181B" BorderBrush="#D4D4D8" BorderThickness="1" CornerRadius="5" ClipToBounds="True" MouseLeftButtonDown="ScreenPreview_OnMouseLeftButtonDown">
                            <Grid>
                                <Image x:Name="ScreenPreview" Stretch="Uniform" />
                                <TextBlock x:Name="PreviewPlaceholder" Text="Preview appears while running" Foreground="#A1A1AA" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" />
                            </Grid>
                        </local:AspectRatioBorder>
                        <TextBlock x:Name="PreviewTimeText" Text="NO CAPTURE YET" Style="{StaticResource MetricLabel}" Margin="0,7,0,12" />
                        <Border Background="#FAFAFA" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Teach an unfamiliar screen" FontSize="12" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                    <Button x:Name="TeachScreenButton" Content="TEACH THIS SCREEN" FontSize="10" Padding="10,5" Click="TeachScreen_OnClick" DockPanel.Dock="Right" />
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="When clicked:" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="TeachActionBox" SelectedIndex="0" Width="145" Height="28">
                                        <ComboBoxItem Content="Continue / JOIN" />
                                        <ComboBoxItem Content="Back / cancel" />
                                        <ComboBoxItem Content="Confirm / OK" />
                                        <ComboBoxItem Content="Custom next step" />
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="TeachStatusText" Text="If ASA pauses on a new screen, capture it here and click the control that should be used next." TextWrapping="Wrap" Foreground="#52525B" FontSize="11" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <TextBox x:Name="ActivityBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="170" BorderThickness="0" Background="White" Foreground="{StaticResource InkBrush}" FontFamily="Consolas" FontSize="11" />
                        <TextBlock Text="Session captures" Style="{StaticResource MetricLabel}" Margin="0,14,0,7" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="180" Background="#F4F4F5" Padding="8">
                            <StackPanel x:Name="EvidenceStrip" Orientation="Horizontal" />
                        </ScrollViewer>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
